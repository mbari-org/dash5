# Widget data host (used by VehicleDiagram / VehicleList to fetch /widget/auv_*.json).
# Must be NEXT_PUBLIC_ so the variable is accessible in the browser bundle.
# Dev:  http://localhost:3002  (api-proxy.js forwards to okeanids.mbari.org)
# Prod: https://okeanids.mbari.org  (or wherever the widget JSON files are served)
NEXT_PUBLIC_API_HOST=http://localhost:3002
NEXT_PUBLIC_BASE_URL=http://localhost:3002/TethysDash/api
NEXT_PUBLIC_ODSS2BASE_URL=http://localhost:3002/odss2dash/api
NEXT_PUBLIC_WEBSOCKET_URL=wss://okeanids.mbari.org/ws/
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<your key here>
NEXT_PUBLIC_ESRI_API_KEY=<your key here>

# ── MBARI SSO (Microsoft Entra ID) ──────────────────────────────────────────
# This app is a public client (static export / SPA) — no client secret is used
# or required. Tokens are acquired entirely in the browser via MSAL redirect flow.
#
# Client ID from the MBARI Entra ID app registration for Dash5.
# NOTE: A new app registration must be created in Entra ID specifically for
# Dash5 (separate from the sinkerdev registration). Replace this placeholder
# with the Client ID from that registration.
NEXT_PUBLIC_MSAL_CLIENT_ID=<dash5-entra-client-id>
#
# Redirect URI must match exactly what is registered in Entra ID.
# The registered URIs should point to the static app root (not a server callback):
#   https://dash5.mbari.org/            (production)
#   https://dash5-staging.mbari.org/   (staging)
#   http://localhost:3000/              (local dev)
# Set this variable to match the current deployment environment.
NEXT_PUBLIC_MSAL_REDIRECT_URI=http://localhost:3000/